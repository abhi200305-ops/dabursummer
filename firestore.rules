rules_version = '2';
// Dabur Beat App — prototype rules.
// Anonymous Auth required. Role gating happens at app level (PIN / admin password).
// Harden before any production rollout.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
